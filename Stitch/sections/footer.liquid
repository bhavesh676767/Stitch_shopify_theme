{% comment %} MARCOS ALPHA Premium World-Class Footer {% endcomment %}

<link rel="stylesheet" href="{{ 'footer.css' | asset_url }}">

<footer class="site-footer">
  <div class="footer-container">
    <!-- Top Footer Info -->
    <div class="footer-top-grid">
      
      <!-- Brand column -->
      <div class="footer-column brand-column">
        <h3 class="footer-brand">MARCOS ALPHA</h3>
        <p class="footer-tagline">LIMITED RELEASES / EXCLUSIVE COUTURE / STREET CULTURE</p>
        <div class="footer-socials">
          {%- if settings.social_instagram_link != blank or true -%}
            <a href="{{ settings.social_instagram_link | default: '#' }}" class="social-icon" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank or true -%}
            <a href="{{ settings.social_tiktok_link | default: '#' }}" class="social-icon" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank or true -%}
            <a href="{{ settings.social_twitter_link | default: '#' }}" class="social-icon" aria-label="Twitter">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Links Column 1 -->
      <div class="footer-column links-column">
        <h4 class="footer-col-title">SHOPPING</h4>
        <ul class="footer-menu">
          {%- for link in section.settings.menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
            <li><a href="/pages/sizing-chart">Sizing Guide</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Links Column 2 -->
      <div class="footer-column links-column">
        <h4 class="footer-col-title">INFO</h4>
        <ul class="footer-menu">
          {%- for link in section.settings.secondary_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="/pages/about">Our Story</a></li>
            <li><a href="/pages/mission">Mission</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Newsletter Column -->
      <div class="footer-column newsletter-column">
        <h4 class="footer-col-title">JOIN THE CLAN</h4>
        <p class="newsletter-desc">Subscribe to receive notifications for secret drops and new designs.</p>
        {%- form 'customer', class: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-input-group">
            <input
              type="email"
              name="contact[email]"
              id="NewsletterEmail-{{ section.id }}"
              class="newsletter-input"
              placeholder="ENTER EMAIL ADDRESS"
              required
              aria-label="Email address"
            >
            <button type="submit" class="newsletter-submit" name="commit" aria-label="Subscribe">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </div>
        {%- endform -%}
      </div>

    </div>

    <!-- Bottom Footer copyright & details -->
    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <p class="copyright-text">&copy; {{ 'now' | date: '%Y' }} MARCOS ALPHA. ALL RIGHTS RESERVED.</p>
        <div class="policy-links">
          <a href="/policies/privacy-policy">PRIVACY</a>
          <a href="/policies/terms-of-service">TERMS</a>
          <a href="/policies/refund-policy">REFUNDS</a>
        </div>
      </div>
      
      <div class="footer-bottom-right">
        {%- if section.settings.show_payment_icons -%}
          <div class="footer-payments">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Primary Menu",
      "info": "Display primary links"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary Menu",
      "info": "Display secondary links"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ]
}
{% endschema %}
