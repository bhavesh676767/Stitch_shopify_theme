{% comment %} MARCOS ALPHA Premium iOS Floating Navbar {% endcomment %}

<link rel="stylesheet" href="{{ 'header.css' | asset_url }}">

<!-- DESKTOP FLOATING NAVBAR -->
<header class="floating-navbar" id="site-header">
  <div class="navbar-container">
    
    <!-- LOGO (LEFT) -->
    <a href="{{ routes.root_url }}" class="navbar-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 180 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="navbar-logo-text">MARCOS ALPHA</span>
      {%- endif -%}
    </a>

    <!-- CENTER NAV LINKS -->
    <nav class="navbar-links" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="nav-link {% if link.active %}active{% endif %}">{{ link.title | upcase }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="nav-link">SHOP</a>
        <a href="/pages/about" class="nav-link">ABOUT</a>
      {%- endfor -%}
    </nav>

    <!-- RIGHT SIDE ACTIONS -->
    <div class="navbar-right">
      <a href="{{ routes.search_url }}" class="icon-btn search-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="icon-btn cart-btn" aria-label="Shopping Bag">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="nav-link login-link">
          {%- if customer -%}ACCOUNT{%- else -%}LOGIN{%- endif -%}
        </a>
      {%- endif -%}
    </div>

  </div>
</header>

<!-- MOBILE BOTTOM FLOATING NAV -->
<nav class="mobile-bottom-nav" aria-label="Mobile navigation">
  <div class="mobile-nav-container">
    <a href="{{ routes.root_url }}" class="mob-nav-item {% if request.page_type == 'index' %}active{% endif %}">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>Home</span>
    </a>

    <a href="{{ routes.all_products_collection_url }}" class="mob-nav-item {% if request.page_type == 'collection' or request.page_type == 'list-collections' %}active{% endif %}">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="7" height="7"/><rect x="15" y="3" width="7" height="7"/><rect x="15" y="15" width="7" height="7"/><rect x="2" y="15" width="7" height="7"/>
      </svg>
      <span>Shop</span>
    </a>

    <a href="{{ routes.cart_url }}" class="mob-nav-item {% if request.page_type == 'cart' %}active{% endif %}">
      <span class="mob-cart-wrap">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="mob-cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </span>
      <span>Bag</span>
    </a>

    {%- if shop.customer_accounts_enabled -%}
      <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="mob-nav-item {% if request.page_type contains 'customer' %}active{% endif %}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        <span>Account</span>
      </a>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 40,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Logo width",
      "default": 100
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
